# API接口扫描路径
ROUTER_PATH = 'src/api'


# ==================== 网关配置 ====================

# 目标后端服务地址
TARGET_API_URL=http://127.0.0.1:8080
TARGET_API_VERSION=v1
TARGET_API_KEY=sk-123

# 网关监听端口
GATEWAY_PORT=9000
GATEWAY_HOST=0.0.0.0

# 数据库路径（相对于项目根目录）
DB_PATH=./database/db.sqlite

# 清理配置（天数）
CLEANUP_DAYS=30

# 清理执行间隔，默认3600000，1小时
CLEANUP_INTERVAL_MS = 3600000

# 请求超时时间（毫秒）
REQUEST_TIMEOUT=30000

# 请求时间间隔（毫秒）
REQUEST_INTERVAL_MS=300

# 是否启用控制台打印log
CONSOLE_LOG=log,warn,error,info