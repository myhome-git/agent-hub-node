# API接口扫描路径
ROUTER_PATH = 'src/api'


# ==================== 网关配置 ====================

# 目标后端服务地址
TARGET_URL=https://ai-api-qwen36.myhome1985.cc.cd

# 网关监听端口
GATEWAY_PORT=9000

# WebSocket 端口
WS_PORT=9001

